# Copy to .env.local (local dev) and set the same variables in your hosting provider for production.

# --- Local development ---
# LANGFLOW_API_URL=http://localhost:7860/api/v1/run/your-flow-id

# --- Production (Vercel, etc.) ---
# IMPORTANT: Production servers cannot reach localhost. Use a publicly reachable Langflow URL:
# LANGFLOW_URL=https://your-langflow-host.example.com
# LANGFLOW_FLOW_ID=c8844d99-db38-4df8-9519-2b5a77fd231f
#
# Or set the full run URL:
# LANGFLOW_API_URL=https://your-langflow-host.example.com/api/v1/run/your-flow-id

# Langflow API key (server-side only — never expose to the browser)
LANGFLOW_API_KEY=

# After deploying, verify configuration:
# GET https://your-site.com/api/langflow/health?probe=true
