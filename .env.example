# Copy to .env.local and fill in your values. Never commit .env.local.

# Option A: full run endpoint URL
LANGFLOW_API_URL=http://localhost:7860/api/v1/run/c8844d99-db38-4df8-9519-2b5a77fd231f

# Option B: base URL + flow ID (used if LANGFLOW_API_URL is unset)
# LANGFLOW_URL=http://localhost:7860
# LANGFLOW_FLOW_ID=c8844d99-db38-4df8-9519-2b5a77fd231f

# Langflow API key (server-side only — never expose to the browser)
LANGFLOW_API_KEY=
