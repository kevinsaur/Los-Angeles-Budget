# Copy to .env.local (local dev) and set the same variables in Vercel for production.

# Public Langflow host (Fly.io, cloud, or local for dev only)
LANGFLOW_URL=https://host-langflow-pdovbw.fly.dev

# Flow ID from your Langflow instance (check API access pane after importing flow)
LANGFLOW_FLOW_ID=

# Optional. If your Langflow instance requires auth, set a valid API key.
# If empty, the app will not send the x-api-key header.
LANGFLOW_API_KEY=

# Verify after deploy:
# GET https://losangelesbudget.com/api/langflow/health?probe=true
